{
    "name": "SharePoint Online View by Default",
    "version": "2.0.0",
    "description": "Sets the default document behaviour of SharePoint Online to view",
    "homepage_url": "https://github.com/tanakrit-d/sharepoint-default-view",
    "icons": {
        "16": "assets/icons/16.png",
        "32": "assets/icons/32.png",
        "48": "assets/icons/48.png",
        "128": "assets/icons/128.png"
    },
    "manifest_version": 3,
    "permissions": [
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "https://*.sharepoint.com/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    }
}